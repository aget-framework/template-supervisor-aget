    "problem": "Current names don't indicate risk level"
  },
  "risk_taxonomy": {
    "level_1_safe": {
      "characteristics": ["read-only", "no side effects", "can't break anything"],
      "signal_words": ["analytics", "monitor", "tracker", "watcher", "observer"],
      "examples": ["my-spotify-analytics-aget", "my-ga4-monitor-aget"],
      "color_code": "🟢"
    },
    "level_2_medium": {
      "characteristics": ["local writes", "reversible", "affects user space only"],
      "signal_words": ["manager", "organizer", "assistant", "helper"],
      "examples": ["my-notes-manager-aget", "my-files-organizer-aget"],
      "color_code": "🟡"
    },
    "level_3_high": {
      "characteristics": ["production writes", "public impact", "hard to reverse"],
      "signal_words": ["publisher", "operator", "controller", "deployer"],
      "examples": ["content-publisher-aget", "infra-operator-aget"],
      "color_code": "🔴"
    }
  },
  "naming_formula": "[ownership]-[domain]-[risk_signal]-aget",
  "real_world_examples": {
    "spotify_agent": {
      "current": "spotify-aget",
      "better": "my-spotify-analytics-aget",
      "why": "Clearly read-only personal analytics"
    },
    "rkb_content": {
      "current": "RKB_content-enhancement",
      "better": "RKB-content-publisher-aget",
      "why": "Clearly production publisher with high stakes"
    },
    "infrastructure": {
      "current": "RKB_infrastructure",
      "better": "RKB-infra-monitor-aget",
      "why": "Clearly read-only monitoring (InfraGuard pattern)"
    }
  },
  "team_naming_insight": {
    "problem": "team- prefix is ambiguous (private team? public team?)",
    "solution": {
      "public_teams": ["oss-team-", "public-team-", "community-"],
      "private_teams": ["corp-team-", "internal-team-", "acme-team-"],
      "personal_teams": ["my-team-"]
    }
  },
  "safety_benefits": [
    "Instant risk assessment from name alone",
    "Prevents accidental execution of high-risk agents",
